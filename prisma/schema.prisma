generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id    String @id @default(cuid())
  name  String @unique // "Admin", "Conseil syndical", "Read-only"
  users User[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  
  status    String   @default("PENDING") // PENDING, ACTIVE, DISABLED
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  dossiersSuivis   Dossier[] @relation("ResponsableCS")
  dossiersActions  Dossier[] @relation("ActionUser")
  commentaires     Commentaire[]
  activityLogs     ActivityLog[]
  archivedDossiers Dossier[] @relation("ArchivedDossiers")
  notifications    Notification[]
  finalizedDossiers Dossier[] @relation("FinalizedDossiers")
  closedDossiers   Dossier[] @relation("ClosedDossiers")
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  dossiers Dossier[]
}

model Dossier {
  id                String      @id @default(cuid())
  reference         String      @unique
  title             String
  description       String
  statut            String      // e.g. nouveau, en_analyse, resolu, cloture
  priorite          String      // e.g. basse, moyenne, haute, urgente
  amount            Float?

  // Localisation
  building          String?     @default("Le Bâtiment Unique")
  lotZone           String?
  niveau            String?
  localisation      String?
  typeLocalisation  String?
  precision         String?

  // Relations
  categoryId        String
  category          Category    @relation(fields: [categoryId], references: [id])
  
  responsableCSId   String?
  responsableCS     User?       @relation("ResponsableCS", fields: [responsableCSId], references: [id], onDelete: SetNull)
  
  prestataireId     String?
  prestataire       Prestataire? @relation(fields: [prestataireId], references: [id], onDelete: SetNull)
  
  actionUserId      String?
  actionUser        User?       @relation("ActionUser", fields: [actionUserId], references: [id], onDelete: SetNull)
  
  typeDossier       String       @default("Autre") // Sécurité, Travaux, Chauffage, Espaces verts, Juridique, Autre
  
  // Specific Heating Fields
  typeInstallation  String?
  contratMaintenance String?
  lastMaintenance   DateTime?
  nextDeadline      DateTime?

  // Dates
  dueDate           DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  etapes            Etape[]
  commentaires      Commentaire[]
  documents         Document[]

  archived         Boolean   @default(false)
  archivedAt       DateTime?
  archivedById     String?
  archivedBy       User?     @relation("ArchivedDossiers", fields: [archivedById], references: [id])

  finalDecision    String?
  finalizedAt      DateTime?
  finalizedById    String?
  finalizedBy      User?     @relation("FinalizedDossiers", fields: [finalizedById], references: [id])

  closedAt         DateTime?
  closedById       String?
  closedBy         User?     @relation("ClosedDossiers", fields: [closedById], references: [id])
}

model Etape {
  id          String   @id @default(cuid())
  title       String
  statut      String
  comment     String?
  date        DateTime @default(now())
  
  dossierId   String
  dossier     Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model Commentaire {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  dossierId   String
  dossier     Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String
  url         String
  description String?
  createdAt   DateTime @default(now())
  
  dossierId   String
  dossier     Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "CREATED", "UPDATED_STATUS"
  targetType  String   // e.g. "Dossier", "Etape", "Document"
  targetId    String   
  createdAt   DateTime @default(now())
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prestataire {
  id        String   @id @default(cuid())
  nom       String
  type      String   // technique, espaces verts, chauffage, juridique, syndic
  email     String?
  telephone String?
  actif     Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dossiers  Dossier[]
}

